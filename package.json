{
  "name": "scrap-machine",
  "version": "0.1.0",
  "description": "Multiplayer clicker/strategy game for Gamedev.js Jam 2026 — theme: Machines",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bigboy1122/scrap-machine.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bigboy1122/scrap-machine/issues"
  },
  "homepage": "https://github.com/bigboy1122/scrap-machine#readme",
  "dependencies": {
    "phaser": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
